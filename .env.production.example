# ============================================================
# production — 운영 (백엔드 application-prod.yml / .env.docker 과 쌍)
#   Vercel·자체 서버 등: 호스팅 대시보드에 동일 키로 등록
#   로컬에서 production 빌드 테스트: .env.production.local 사용 (Git 무시)
#
# OAuth 클라이언트 ID/Secret 은 NextAuth(프론트 Node)만 사용 — application.yml 에 넣어도 적용 안 됨.
# ============================================================

# 실제 관리자 사이트 공개 URL (승인 리디렉션 URI: {NEXTAUTH_URL}/api/auth/callback/google 등)
NEXTAUTH_URL=https://admin.example.com

# 무작위 값 생성: 프로젝트 루트에서 `pnpm gen:secrets` (NEXTAUTH_SECRET + OAUTH_SYNC_SECRET 한 번에 출력)
# PowerShell에 openssl 있으면: openssl rand -hex 32
# OAUTH_SYNC_SECRET 은 백엔드 application.yml 의 app.oauth-sync.secret 과 문자열이 완전히 같아야 함
NEXTAUTH_SECRET=c8371c006cedb7a9a18856c2d88ff24389be029e35d515e847809dd0c73c9b4c
# NEXTAUTH_SECRET 대신 AUTH_SECRET 만 써도 됨 (auth.ts)
OAUTH_SYNC_SECRET=b60509677d0f13c9ccf01034dafefee4b0679878278033a1815397e787e3932f

# 운영 API (공인 IP 또는 https://api.도메인)
API_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# 백엔드 .env.docker 의 APP_CORS_EXTRA_ORIGINS 에 반드시 아래와 같은 "프론트 오리진" 포함
# (브라우저 주소창 기준). 예: NEXTAUTH_URL 이 http://13.x.x.x:3001 이면 그 전체를 CORS에 추가

# (선택) 푸터·링크용 사용자 사이트
# NEXT_PUBLIC_USER_SITE_URL=https://example.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
