# ============================================================
# production — 운영 (백엔드 application-prod.yml / .env.docker 과 쌍)
#   Vercel·Cloudflare Pages·자체 서버: 대시보드에 동일 키로 등록
#   로컬에서 production 빌드 테스트: cp .env.production.example .env.production.local
# ============================================================

# 실제 관리자 사이트 공개 URL (승인 리디렉션 URI에도 사용)
NEXTAUTH_URL=https://admin.example.com
NEXTAUTH_SECRET=CHANGE_ME_PROD_RANDOM_LONG_STRING

# 백엔드 .env.docker 의 OAUTH_SYNC_SECRET 과 문자열 완전 동일
OAUTH_SYNC_SECRET=CHANGE_ME_SAME_AS_BACKEND_PROD

# 운영 API (공인 IP 또는 https://api.도메인)
API_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# 백엔드 .env.docker 의 APP_CORS_EXTRA_ORIGINS 에 반드시 아래와 같은 "프론트 오리진" 포함
# (브라우저 주소창 기준). 예: NEXTAUTH_URL 이 http://13.x.x.x:3001 이면 그 전체를 CORS에 추가

# (선택) 푸터·링크용 사용자 사이트
# NEXT_PUBLIC_USER_SITE_URL=https://example.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
