# ============================================================
# local — PC 개발 (백엔드 application-local.yml 과 쌍)
#   복사: cp .env.local.example .env.local
#   Next: pnpm dev (또는 npm run dev)
# ============================================================

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_LONG_STRING

# 백엔드 app.oauth-sync.secret / OAUTH_SYNC_SECRET 과 동일 (로컬 기본값 쓰려면 application.yml 기본과 맞출 것)
OAUTH_SYNC_SECRET=prjt-dev-oauth-sync-7f3a9b2c1d4e8e0f

API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# (선택) OAuth — 콘솔에 리디렉션 URI: http://localhost:3001/api/auth/callback/...
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
