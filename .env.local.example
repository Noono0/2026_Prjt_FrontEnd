# ============================================================
# local — PC 개발 (백엔드 application-local.yml 과 쌍)
#   복사: cp .env.local.example .env.local
#   Next: pnpm dev (또는 npm run dev)
#
# NextAuth 는 이 파일(및 OS 환경변수)만 읽습니다. 백엔드 application.yml 과 무관.
# secret 은 NEXTAUTH_SECRET 또는 AUTH_SECRET 중 하나만 있어도 됨 (auth.ts).
# ============================================================

NEXTAUTH_URL=http://localhost:3001
# 무작위: `pnpm gen:secrets` 로 NEXTAUTH / OAUTH_SYNC 한 번에 생성 (OAUTH 는 백엔드와 동일하게 맞출 것)
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_LONG_STRING

# 백엔드 application.yml 의 app.oauth-sync.secret / env OAUTH_SYNC_SECRET 과 동일 문자열
OAUTH_SYNC_SECRET=prjt-dev-oauth-sync-7f3a9b2c1d4e8e0f

API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- OAuth (프론트 NextAuth 전용 — ID·Secret 쌍이 있어야 로그인 버튼 활성) ---
# 리디렉션 URI 예: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 리디렉션 URI 예: {NEXTAUTH_URL}/api/auth/callback/kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 리디렉션 URI 예: {NEXTAUTH_URL}/api/auth/callback/naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
