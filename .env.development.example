# ============================================================
# development / dev — 스테이징·팀 공용 API (백엔드 application-dev.yml 과 쌍)
#   복사: cp .env.development.example .env.development.local
#   또는 .env.local 에서 URL만 스테이징으로 바꿔 사용해도 됨
# ============================================================

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_LONG_STRING

# 백엔드 dev 인스턴스의 OAUTH_SYNC_SECRET 과 동일
OAUTH_SYNC_SECRET=CHANGE_ME_SAME_AS_BACKEND_DEV

# 스테이징 API 베이스 (예시 — 실제 호스트로 교체)
API_BASE_URL=https://dev-api.example.com
NEXT_PUBLIC_API_BASE_URL=https://dev-api.example.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
